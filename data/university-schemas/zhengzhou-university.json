{
  "id": "zhengzhou-university",
  "displayName": "Zhengzhou University",
  "formUrl": "https://zzu.17gz.org/apply/index.do",
  "wizard": {
    "totalSteps": 7,
    "nextButtonSelector": "input[value='Save and Next'], input[value='Next']",
    "submitButtonSelector": "input[value='Submit'], button[type='submit']"
  },
  "aliases": [
    "Zhengzhou University",
    "Zhengzhou Univ",
    "Zhengzhou Univ.",
    "University of Zhengzhou",
    "ZZU",
    "郑州大学",
    "Zhengzhou State University"
  ],
  "requiredDocuments": ["photo", "passport", "transcript", "medical", "financial"],
  "fields": [
    {
      "selector": "input[name='apply.lastName']",
      "mapsTo": "personal.surname",
      "type": "text",
      "required": true,
      "wizardStep": 1
    },
    {
      "selector": "input[name='apply.givenName']",
      "mapsTo": "personal.givenName",
      "type": "text",
      "required": true,
      "wizardStep": 1
    },
    {
      "selector": "input[name='apply.name']",
      "mapsTo": "personal.chineseName",
      "type": "text",
      "required": false,
      "wizardStep": 1
    },
    {
      "selector": "input[type='radio'][name='apply.sex']",
      "mapsTo": "personal.sex",
      "type": "radio",
      "required": true,
      "wizardStep": 1
    },
    {
      "selector": "input[name='apply.bornedDate']",
      "mapsTo": "personal.dateOfBirth",
      "type": "text",
      "required": true,
      "wizardStep": 1
    },
    {
      "selector": "select[name='apply.countryId']",
      "mapsTo": "personal.nationality",
      "type": "select",
      "required": true,
      "wizardStep": 1
    },
    {
      "selector": "input[name='apply.passportNo']",
      "mapsTo": "personal.passportNo",
      "type": "text",
      "required": true,
      "wizardStep": 1
    },
    {
      "selector": "input[name='apply.passportExpire']",
      "mapsTo": "personal.passportExpiry",
      "type": "text",
      "required": false,
      "wizardStep": 1
    },
    {
      "selector": "input[name*='email']",
      "mapsTo": "personal.email",
      "type": "text",
      "required": true,
      "wizardStep": 1
    },
    {
      "selector": "textarea[name='studyPlan']",
      "mapsTo": null,
      "type": "essay",
      "required": false,
      "wizardStep": 2,
      "essayPrompt": "Explain your study plan and motivation."
    },
    {
      "selector": "input[name*='mobile'], input[name*='phone']",
      "mapsTo": "personal.phone",
      "type": "text",
      "required": true,
      "wizardStep": 5
    },
    {
      "selector": "textarea[name='permanentAddress']",
      "mapsTo": "personal.permanentAddress",
      "type": "textarea",
      "required": false,
      "wizardStep": 5
    },
    {
      "selector": "input[name='passport'], input[type='file'][name*='passport']",
      "mapsTo": null,
      "type": "file",
      "required": true,
      "wizardStep": 6,
      "documentType": "passport"
    },
    {
      "selector": "input[name='photo']",
      "mapsTo": null,
      "type": "file",
      "required": true,
      "wizardStep": 6,
      "documentType": "photo"
    },
    {
      "selector": "input[name='transcript'], input[type='file'][name*='transcript']",
      "mapsTo": null,
      "type": "file",
      "required": true,
      "wizardStep": 6,
      "documentType": "transcript"
    },
    {
      "selector": "input[name='medical'], input[type='file'][name*='medical']",
      "mapsTo": null,
      "type": "file",
      "required": true,
      "wizardStep": 6,
      "documentType": "medical"
    },
    {
      "selector": "input[name='financial'], input[type='file'][name*='financial']",
      "mapsTo": null,
      "type": "file",
      "required": true,
      "wizardStep": 6,
      "documentType": "financial"
    }
  ],
  "requiresEssay": true,
  "essayPrompt": "Explain why you want to study at Zhengzhou University.",
  "notes": "17gz 7-step wizard. Pre-wizard screens (Agree, program selection) require manual navigation. Selectors synced from zzu-recon-fill.mjs."
}
