{
  "id": "lnpu",
  "displayName": "Liaoning Petrochemical University",
  "formUrl": "http://lnpu.chiwest.cn/en/student/apply/index",
  "defaultProgram": "Master",
  "session": {
    "loginUrlPattern": "/student/login(?:/|$|\\?)",
    "expiredIndicators": ["Don't have an account?"]
  },
  "aliases": [
    "Liaoning Petrochemical University",
    "Liaoning Shihua University",
    "LNPU",
    "辽石化",
    "辽宁石油化工大学",
    "lnpu.chiwest.cn"
  ],
  "requiredDocuments": [
    "photo",
    "passport",
    "transcript",
    "diploma",
    "recommendation_letter"
  ],
  "fields": [
    {
      "selector": "input[name=\"apply[duration_start]\"]",
      "mapsTo": null,
      "type": "text",
      "required": true,
      "wizardStep": 1,
      "labelHint": "Hope Learning Start Time",
      "options": ["2026-09-01"]
    },
    {
      "selector": "input[name=\"apply[duration_end]\"]",
      "mapsTo": null,
      "type": "text",
      "required": true,
      "wizardStep": 1,
      "labelHint": "Hope Learning End Time",
      "options": ["2029-07-01"]
    },
    {
      "selector": "input[name=\"student[last_name]\"]",
      "mapsTo": "personal.surname",
      "type": "text",
      "required": true,
      "wizardStep": 1,
      "labelHint": "Family Name"
    },
    {
      "selector": "input[name=\"student[first_name]\"]",
      "mapsTo": "personal.givenName",
      "type": "text",
      "required": true,
      "wizardStep": 1,
      "labelHint": "Given Name"
    },
    {
      "selector": "input[name=\"passport[number]\"]",
      "mapsTo": "personal.passportNo",
      "type": "text",
      "required": true,
      "wizardStep": 1,
      "labelHint": "Passport Number"
    },
    {
      "selector": "input[name=\"passport[due_time]\"]",
      "mapsTo": "personal.passportExpiry",
      "type": "text",
      "required": true,
      "wizardStep": 1,
      "labelHint": "Passport Expiration Date"
    },
    {
      "selector": "select[name=\"passport[passport_type]\"]",
      "mapsTo": null,
      "type": "select",
      "required": true,
      "wizardStep": 1,
      "labelHint": "Passport Type",
      "options": ["Ordinary Passport"]
    },
    {
      "selector": "input[name=\"student[name]\"]",
      "mapsTo": "personal.chineseName",
      "type": "text",
      "required": false,
      "wizardStep": 1,
      "labelHint": "Chinese Name"
    },
    {
      "selector": "select[name=\"student[gender]\"]",
      "mapsTo": "personal.sex",
      "type": "select",
      "required": true,
      "wizardStep": 1,
      "labelHint": "Gender"
    },
    {
      "selector": "select[name=\"student[marital_status]\"]",
      "mapsTo": "personal.maritalStatus",
      "type": "select",
      "required": false,
      "wizardStep": 1,
      "labelHint": "Marital Status",
      "options": ["single"]
    },
    {
      "selector": "select[name=\"student[nationality_id]\"]",
      "mapsTo": "personal.nationality",
      "type": "select",
      "required": true,
      "wizardStep": 1,
      "labelHint": "Nationality"
    },
    {
      "selector": "input[name=\"student[birthdate]\"]",
