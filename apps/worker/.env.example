DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uni_apply
# Railway: use ${{Postgres.DATABASE_URL}} from the linked Postgres plugin — NOT localhost
REDIS_URL=redis://localhost:6379
# Railway: use ${{Redis.REDIS_URL}} from the linked Redis plugin

GEMINI_API_KEY=
GEMINI_DOCUMENT_MODEL=gemini-3.5-flash
GEMINI_LETTER_MODEL=gemini-3.5-flash

R2_BUCKET=uni-apply
R2_PUBLIC_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_REGION=auto

TELEGRAM_BOT_TOKEN=
CONSULTANT_CHAT_ID=

EXTENSION_API_KEY=

# Persistent browser profiles (one directory per university)
# Used only when no *_SESSION_STATE_B64 / ZZU_SESSION_STATE_B64 is set.
# Capture → Railway workflow pushes B64; that path takes priority over profiles.
# BROWSER_PROFILES_DIR=/data/profiles
# Local only — never set on Railway (needs system Chrome at /opt/google/chrome)
# BROWSER_CHANNEL=chrome
# BROWSER_HEADED=1

# Session capture (without Volume fallback):
# pnpm capture:session -- --university=shandong-university
# → browser-sessions/shandong-university.json.b64
# SHANDONG_UNIVERSITY_SESSION_STATE_B64=...

# Form fill mode: schema | hybrid | agent
# hybrid = CSS/labelHint first, Gemini fallback for missing fields
# agent  = full Observe→Think→Act loop (replaces wizard pipeline)
FORM_FILL_MODE=hybrid
GEMINI_API_KEY=
GEMINI_AGENT_MODEL=gemini-3.5-flash
# AGENT_MAX_STEPS=40
# AGENT_USE_VISION=1

# SDU / CUCAS session capture: pnpm --filter worker capture:sdu-session
SDU_SESSION_STATE_B64=
# SDU_PROFILE_DIR=./profiles/shandong-university
# SDU_USE_PROFILE=1
# BROWSER_PROFILE_DIR_SHANDONG_UNIVERSITY=/data/profiles/sdu

# Legacy ZZU session (fallback when BROWSER_PROFILES_DIR is not set)
# Generate locally: pnpm --filter worker capture:zzu-session
ZZU_SESSION_STATE_B64=

# KMMC (17gz twin of ZZU): pnpm --filter worker capture:kmmc-session
# → Railway: KMMC_SESSION_STATE_B64=<browser-sessions/kmmc.json.b64>
# KMMC_SESSION_STATE_B64=

# Optional: after capture:zzu-session / capture:session, auto-upsert session B64 to Railway worker
# Token: https://railway.com/account/tokens
# IDs: Ctrl+K in Railway → Copy Project/Environment/Service ID (service = worker)
# RAILWAY_API_TOKEN=
# RAILWAY_PROJECT_ID=
# RAILWAY_ENVIRONMENT_ID=
# RAILWAY_SERVICE_ID=

# Legacy ZZU browser tuning (optional)
# ZZU_BROWSER_CHANNEL=chrome
# ZZU_USE_PROFILE=0
# ZZU_PROFILE_DIR=./zzu-browser-profile
# ZZU_CDP_URL=http://127.0.0.1:9222
# ZZU_USE_CDP=1

